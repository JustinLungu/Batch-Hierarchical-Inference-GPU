# Fixed thesis reproduction choices.
#
# These values reproduce the thesis setup. Do not edit them for normal CPU/GPU
# comparison runs; change config/experiment.env for runtime settings such as
# DEVICE, ExPECA IPs, and CONTROLLER_MAX_SAMPLES.

SAMPLE_PATH=data/datasets/imagenetV2/matched-frequency-format-val

SML_ARCH=mobilenet_v3_large
SML_MODEL=data/models/sml/mobilenet_v3_large_imagenet1k_v2.pth

LML_ARCH=vit_h_14
LML_MODEL=data/models/lml/ViT_H_14_Weights_IMAGENET1K_SWAG_E2E_V1.pth

FLUSH_FINAL_BATCH=true
BATCH_WAIT_TIME=3.0
