# Stable project defaults.
#
# These values are not usually changed between experiments. Put run-specific
# choices such as IPs, models, offloading method, and batch sizes in
# config/experiment.env.

PYTHON_VERSION=3.10
VENV_DIR=.venv

DATA_DIR=data
DATASET_DIR=data/datasets
MODEL_DIR=data/models
RESULTS_DIR=results

# Dataset sources used by scripts/download_dataset.sh.
IMAGENETTE_NAME=imagenette2-160
IMAGENETTE_URL=https://s3.amazonaws.com/fast-ai-imageclas/imagenette2-160.tgz
IMAGENETTE_SAMPLE_PATH=data/datasets/imagenette2-160/val

IMAGENETV2_NAME=imagenetV2
IMAGENETV2_DIR=data/datasets/imagenetV2
IMAGENETV2_SPLIT=matched-frequency-format-val
IMAGENETV2_URL=https://huggingface.co/datasets/vaishaal/ImageNetV2/resolve/main/imagenetv2-matched-frequency.tar.gz
IMAGENETV2_SAMPLE_PATH=data/datasets/imagenetV2/matched-frequency-format-val

# Canonical model checkpoint paths used by scripts/download_models.sh.
SML_MOBILENET_V3_LARGE_MODEL=data/models/sml/mobilenet_v3_large_imagenet1k_v2.pth
SML_EFFICIENTNET_B3_MODEL=data/models/sml/EfficientNet_B3_Weights_IMAGENET1K_V1.pth
SML_RESNET34_MODEL=data/models/sml/ResNet34_Weights_IMAGENET1K_V1.pth

LML_WIDE_RESNET50_2_MODEL=data/models/lml/Wide_ResNet50_2_Weights_IMAGENET1K_V2.pth
LML_EFFICIENTNET_V2_L_MODEL=data/models/lml/EfficientNet_V2_L_Weights_IMAGENET1K_V1.pth
LML_VIT_H_14_MODEL=data/models/lml/ViT_H_14_Weights_IMAGENET1K_SWAG_E2E_V1.pth

# Default service ports.
EDGE_DEVICE_PORT=8000
EDGE_SERVER_PORT=8001

# ExPECA image defaults.
EXPECA_IMAGE_TAG=cpu-amd64-001
EXPECA_EDGE_SERVER_IMAGE_TAG=cpu-amd64-001
EXPECA_EDGE_DEVICE_IMAGE_TAG=cpu-amd64-001
EXPECA_GPU_EDGE_SERVER_IMAGE_TAG=gpu-amd64-001
EXPECA_EDGE_DEVICE_ARM64_IMAGE_TAG=cpu-arm64-001
EXPECA_IMAGE_PLATFORM=linux/amd64
