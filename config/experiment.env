# Shared local experiment defaults for helper scripts.
#
# Override any value for one command by exporting it first, for example:
#   SML_ARCH=resnet34 scripts/download_models.sh

PYTHON_VERSION=3.10
VENV_DIR=.venv

DATA_DIR=data
DATASET_DIR=data/datasets
MODEL_DIR=data/models
RESULTS_DIR=results

# Small local dataset for first CPU smoke tests.
# DATASET_NAME options currently supported by scripts/download_dataset.sh:
#   imagenette2-160
DATASET_NAME=imagenette2-160
DATASET_URL=https://s3.amazonaws.com/fast-ai-imageclas/imagenette2-160.tgz
SAMPLE_PATH=data/datasets/imagenette2-160/val

# Model choices must match the registries in app/edge_device/edge_device.py
# and app/edge_server/edge_server.py.
# SML_ARCH options:
#   mobilenet_v3_large, efficientnet_b3, resnet34
SML_ARCH=mobilenet_v3_large
SML_MODEL=data/models/sml/mobilenet_v3_large_imagenet1k_v2.pth
# LML_ARCH options:
#   wide_resnet50_2, efficientnet_v2_l, vit_h_14
LML_ARCH=wide_resnet50_2
LML_MODEL=data/models/lml/Wide_ResNet50_2_Weights_IMAGENET1K_V2.pth

# Service endpoint and device settings.
# For local Python/Docker runs, use:
#   EDGE_DEVICE_IP=127.0.0.1
#   EDGE_SERVER_IP=127.0.0.1
# For ExPECA public-IP runs, use the public IPs printed by the notebook.
#
# DEVICE options:
#   auto = use CUDA if available, otherwise CPU
#   cpu  = force CPU
#   cuda = require CUDA and fail if unavailable
DEVICE=cpu
EDGE_DEVICE_IP=130.237.11.115
EDGE_SERVER_IP=130.237.11.114
EDGE_DEVICE_PORT=8000
EDGE_SERVER_PORT=8001

# Baseline experiment defaults for the upcoming fixed-batch server tests.
# DECISION_METHOD options:
#   never_offload, always_offload, fixed_threshold, adaptive_threshold
DECISION_METHOD=always_offload
# OFFLOADING_STRATEGY options:
#   send_individually, size_based_batching, dynamic_batching
OFFLOADING_STRATEGY=size_based_batching
# Edge-server offload batch size.
BATCH_SIZE=8
# Images sent to edge-device per controller request.
CONTROLLER_BATCH_SIZE=64
# Number of images the controller sends in total.
# Use an integer for quick tests, or "all" to run the full selected dataset.
CONTROLLER_MAX_SAMPLES=all
# If true, the edge device sends a final partial size-based batch at the end
# of the request. Example: BATCH_SIZE=8 and CONTROLLER_BATCH_SIZE=12 sends
# one batch of 8 and one final batch of 4. If false, wait for more images.
FLUSH_FINAL_BATCH=true
WAIT_TIME_BETWEEN_SAMPLES=0.1
FIXED_THRESHOLD_VALUE=0.7
BATCH_WAIT_TIME=3.0

# Local Docker helper.
# false = reuse existing local Docker images when present
# true  = rebuild edge_server and edge_device images before running
FORCE_DOCKER_BUILD=false

# ExPECA public-IP CPU baseline image settings.
# Set EXPECA_IMAGE_NAMESPACE to your Docker Hub or registry namespace before
# building/pushing remote images, for example:
#   EXPECA_IMAGE_NAMESPACE=your_dockerhub_user
#   EXPECA_IMAGE_NAMESPACE=ghcr.io/your_github_user
EXPECA_IMAGE_NAMESPACE=justin157
EXPECA_IMAGE_TAG=cpu-amd64-001
# EXPECA_IMAGE_PLATFORM options are Docker platform strings, for example:
#   linux/amd64, linux/arm64
EXPECA_IMAGE_PLATFORM=linux/amd64
