# Shared local experiment defaults for helper scripts.
#
# Override any value for one command by exporting it first, for example:
#   SML_ARCH=resnet34 scripts/download_models.sh

PYTHON_VERSION=3.10
VENV_DIR=.venv

DATA_DIR=data
DATASET_DIR=data/datasets
MODEL_DIR=data/models
RESULTS_DIR=results

# Small local dataset for first CPU smoke tests.
DATASET_NAME=imagenette2-160
DATASET_URL=https://s3.amazonaws.com/fast-ai-imageclas/imagenette2-160.tgz
SAMPLE_PATH=data/datasets/imagenette2-160/val

# Model choices must match the registries in app/edge_device/edge_device.py
# and app/edge_server/edge_server.py.
SML_ARCH=mobilenet_v3_large
SML_MODEL=data/models/sml/mobilenet_v3_large_imagenet1k_v2.pth
LML_ARCH=wide_resnet50_2
LML_MODEL=data/models/lml/Wide_ResNet50_2_Weights_IMAGENET1K_V2.pth

# Local service defaults.
EDGE_DEVICE_IP=127.0.0.1
EDGE_SERVER_IP=127.0.0.1
EDGE_DEVICE_PORT=8000
EDGE_SERVER_PORT=8001

# Baseline experiment defaults for the upcoming fixed-batch server tests.
DECISION_METHOD=always_offload
OFFLOADING_STRATEGY=size_based_batching
BATCH_SIZE=4
CONTROLLER_BATCH_SIZE=4
WAIT_TIME_BETWEEN_SAMPLES=0.1
FIXED_THRESHOLD_VALUE=0.7
BATCH_WAIT_TIME=3.0
