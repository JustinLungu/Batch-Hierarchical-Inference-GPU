# Active experiment configuration.
#
# Edit this file before running local, ExPECA, grid, or thesis reproduction
# experiments. Stable paths, download URLs, ports, and default image tags live in
# config/defaults.env.

# Dataset choices:
#   Imagenette smoke tests: SAMPLE_PATH=${IMAGENETTE_SAMPLE_PATH}
#   Thesis reproduction:   SAMPLE_PATH=${IMAGENETV2_SAMPLE_PATH}
SAMPLE_PATH=data/datasets/imagenetV2/matched-frequency-format-val

# Model choices must match the registries in app/edge_device/edge_device.py
# and app/edge_server/edge_server.py.
# SML_ARCH options:
#   mobilenet_v3_large, efficientnet_b3, resnet34
SML_ARCH=mobilenet_v3_large
SML_MODEL=data/models/sml/mobilenet_v3_large_imagenet1k_v2.pth
# LML_ARCH options:
#   wide_resnet50_2, efficientnet_v2_l, vit_h_14
# Thesis reproduction uses vit_h_14.
LML_ARCH=vit_h_14
LML_MODEL=data/models/lml/ViT_H_14_Weights_IMAGENET1K_SWAG_E2E_V1.pth

# Compute device options:
#   auto = use CUDA if available, otherwise CPU
#   cpu  = force CPU
#   cuda = require CUDA and fail if unavailable
DEVICE=cpu

# Service endpoint settings.
# Local Python/Docker:
#   EDGE_DEVICE_IP=127.0.0.1
#   EDGE_SERVER_IP=127.0.0.1
# ExPECA public-IP:
#   use the public IPs printed by the notebook.
EDGE_DEVICE_IP=130.237.11.115
EDGE_SERVER_IP=130.237.11.114

# Offloading decision options:
#   never_offload, always_offload, fixed_threshold, adaptive_threshold
DECISION_METHOD=always_offload
# Offloading strategy options:
#   send_individually, size_based_batching, dynamic_batching
OFFLOADING_STRATEGY=size_based_batching

# Edge-device -> edge-server offload batch size.
BATCH_SIZE=8
# Controller/laptop -> edge-device request batch size.
CONTROLLER_BATCH_SIZE=64
# Number of images sent in total. Use an integer for smoke tests or "all".
CONTROLLER_MAX_SAMPLES=all

# Batch-size sweep settings for src/run_expeca_batch_grid.py.
BATCH_SIZE_GRID=1,2,4,8,16,32
# Leave empty to reuse CONTROLLER_BATCH_SIZE for every grid run.
CONTROLLER_BATCH_SIZE_GRID=
# BATCH_GRID_PAIR_MODE options:
#   product = test every BATCH_SIZE_GRID x CONTROLLER_BATCH_SIZE_GRID pair
#   zip     = pair items by position; both grids must have the same length
BATCH_GRID_PAIR_MODE=product

# If true, send final partial size-based batches at the end of a request.
FLUSH_FINAL_BATCH=true
FIXED_THRESHOLD_VALUE=0.7
BATCH_WAIT_TIME=3.0

# Local Docker helper.
FORCE_DOCKER_BUILD=false

# ExPECA registry/deployment settings.
# Set this to your Docker Hub username or registry namespace before build/push.
EXPECA_IMAGE_NAMESPACE=justin157
# ExPECA edge-server DEVICE value:
#   cpu  = CPU baseline
#   cuda = GPU server run
EXPECA_EDGE_SERVER_DEVICE=cpu
