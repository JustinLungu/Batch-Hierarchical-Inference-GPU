# Active runtime configuration for thesis reproduction.
#
# Fixed thesis choices live in:
#   config/thesis_reproduction.env
#   config/thesis_configs.csv
#
# Stable paths, download URLs, ports, and default image tags live in:
#   config/defaults.env

# Compute device options:
#   cpu  = CPU thesis reproduction
#   cuda = GPU thesis reproduction on a GPU-capable ExPECA server
DEVICE=cpu

# ExPECA public-IP endpoints printed by the notebook/container creation cells.
EDGE_DEVICE_IP=130.237.11.117
EDGE_SERVER_IP=130.237.11.120

# Number of images sent in total for each thesis configuration.
# Use a small integer for a quick validation run or "all" for the full dataset.
CONTROLLER_MAX_SAMPLES="all"

# ExPECA registry/deployment settings.
# Set this to your Docker Hub username or registry namespace before build/push.
EXPECA_IMAGE_NAMESPACE=justin157

# ExPECA edge-server DEVICE value used by the notebook:
#   cpu  = CPU thesis reproduction
#   cuda = GPU thesis reproduction
EXPECA_EDGE_SERVER_DEVICE=cpu

# Server-side LML inference batching.
# Change these here before CPU/GPU benchmark runs.
#
# LML_BATCHING_MODE options:
#   auto       = sequential on CPU, adaptive on CUDA
#   sequential = one image per LML forward pass
#   fixed      = fixed micro-batches up to LML_INITIAL_BATCH_SIZE
#   adaptive   = start at LML_INITIAL_BATCH_SIZE, grow after success, halve/retry on CUDA OOM
LML_BATCHING_MODE=auto
LML_INITIAL_BATCH_SIZE=8
LML_MIN_BATCH_SIZE=1
LML_MAX_BATCH_SIZE=64
LML_GPU_MEMORY_FRACTION=0.85
LML_OOM_RETRY=true
